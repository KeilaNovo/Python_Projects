print """
 Area - Calculator
 Circle and Triangle area calculator
 """
print "Starting the calculator..."

option = raw_input("Enter a C for Circle or T for Triangle")

if option  == "C":
  radius = float(raw_input("Introduce the radius: "))
  pi = 3.14159
  area = pi * radius**2
  print str(area)

elif option == "T":
  base = float(raw_input("Enter the base: "))
  height = float(raw_input("Enter the height:"))
  area = 0.5 * base * height
  print str(area)

else:
  print "You enter a invalid shape"

print "Exiting from the calculator"
